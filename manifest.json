{
  "manifest_version": 3,
  "name": "SardarIT Reference Engine",
  "version": "2.0",
  "description": "AI-powered Project Matching and Proposal Generator for SardarIT.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_width": 950,
    "default_height": 650
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "storage"
  ]
}